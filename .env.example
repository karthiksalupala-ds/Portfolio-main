# EmailJS Configuration
# Get your credentials from: https://www.emailjs.com/
# 1. Sign up / log in at emailjs.com
# 2. Create a Service (e.g., Gmail) → copy the Service ID
# 3. Create an Email Template → copy the Template ID
# 4. Go to Account → API Keys → copy your Public Key

VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# OpenAI API Key — for the "Ask Karthik" AI chat assistant
# Get your key from: https://platform.openai.com/api-keys
# ✅ NO "VITE_" prefix — this stays SERVER-SIDE only (Vercel function), never exposed in browser
OPENAI_API_KEY=your_openai_api_key_here
